# MedVid Engine — GPU backend (Kling Avatar V2 + MEMO + SadTalker)
REPLICATE_API_TOKEN=

# Animation: "medvid" (défaut) ou "heygen" (référence externe)
ANIMATION_PROVIDER=

# Modèle MedVid : kling (défaut), pruna, sadtalker, memo (lent ~40min)
MEDVID_MODEL=

# Kling : std (rapide, défaut) ou pro (meilleure qualité, plus lent)
KLING_MODE=

# Modèle voix : eleven_v3 (défaut, pauses/soupirs) ou eleven_multilingual_v2
ELEVENLABS_MODEL=

# ElevenLabs API Key
ELEVENLABS_API_KEY=

# OpenAI API Key (for DALL-E image generation)
OPENAI_API_KEY=

# HeyGen — optionnel, seulement si ANIMATION_PROVIDER=heygen
HEYGEN_API_KEY=
